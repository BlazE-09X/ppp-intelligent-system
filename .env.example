# Скопируй этот файл в .env и впиши свои реальные значения.
# Сам файл .env никогда не должен попадать в git (он уже в .gitignore).

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
SECRET_KEY=замени-на-свой-длинный-случайный-ключ

# Логин и пароль администратора (создаются один раз при первом запуске)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=замени-на-надёжный-пароль
